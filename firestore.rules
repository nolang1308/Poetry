rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 관리자 계정 목록 (전화번호 기반 이메일)
    function isAdminEmail(email) {
      return email in [
        '01092375405@poetry-admin.web',
        '01035959152@poetry-admin.web'
      ];
    }

    match /poems/{poemId} {
      // 관리자 계정만
      function isAdmin() {
        return request.auth != null && isAdminEmail(request.auth.token.email);
      }

      // 좋아요: likes 필드만 ±1 변경 허용 (누구나)
      function onlyLikesDelta() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
          && request.resource.data.likes is int
          && (
            request.resource.data.likes == resource.data.likes + 1 ||
            request.resource.data.likes == resource.data.likes - 1
          );
      }

      allow read: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || onlyLikesDelta();
    }

    // 홈 화면 등 사이트 설정: 읽기는 누구나, 쓰기는 관리자만
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && isAdminEmail(request.auth.token.email);
    }
  }
}
