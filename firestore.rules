rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 관리자 계정 목록 (전화번호 기반 이메일)
    function isAdminEmail(email) {
      return email in [
        '01092375405@poetry-admin.web',
        '01035959152@poetry-admin.web'
      ];
    }

    match /poems/{poemId} {
      // 관리자 계정만
      function isAdmin() {
        return request.auth != null && isAdminEmail(request.auth.token.email);
      }

      // 좋아요: 지정한 카운터 필드 하나만 ±1 변경 허용 (누구나).
      // get(field, 0)을 쓰므로 아직 필드가 없는 기존 문서에서도 동작한다.
      function onlyLikeDelta(field) {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([field])
          && request.resource.data[field] is int
          && (
            request.resource.data[field] == resource.data.get(field, 0) + 1 ||
            request.resource.data[field] == resource.data.get(field, 0) - 1
          );
      }

      allow read: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      // likes = 시 본문 좋아요, noteLikes = 시인의 노트 좋아요 (각각 따로 집계)
      allow update: if isAdmin()
        || onlyLikeDelta('likes')
        || onlyLikeDelta('noteLikes');
    }

    // 시집(시 묶음): 읽기는 누구나, 만들기/수정/삭제는 관리자만
    match /books/{bookId} {
      allow read: if true;
      allow write: if request.auth != null
        && isAdminEmail(request.auth.token.email);
    }

    // 게스트 댓글: 읽기는 누구나. 작성은 익명 로그인 포함 로그인 사용자,
    // 수정은 작성자 본인만(content만), 삭제는 본인 또는 관리자.
    match /comments/{commentId} {
      allow read: if true;

      // parentId는 답글일 때만 붙는 선택 필드 — 값이 있으면 원 댓글의 문서 id.
      // (없어도 통과시켜야 규칙을 먼저 배포해도 기존 앱이 깨지지 않는다)
      function validParent() {
        return !('parentId' in request.resource.data)
          || (request.resource.data.parentId is string
            && request.resource.data.parentId.size() <= 64);
      }

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(
          ['poemId', 'nickname', 'content', 'authorUid', 'createdAt', 'parentId'])
        && validParent()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.poemId is string
        && request.resource.data.poemId.size() > 0
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 1
        && request.resource.data.nickname.size() <= 20
        && request.resource.data.content is string
        && request.resource.data.content.size() >= 1
        && request.resource.data.content.size() <= 500
        && request.resource.data.createdAt is int;

      allow update: if request.auth != null
        && request.auth.uid == resource.data.authorUid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['content'])
        && request.resource.data.content is string
        && request.resource.data.content.size() >= 1
        && request.resource.data.content.size() <= 500;

      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.authorUid
          || isAdminEmail(request.auth.token.email));
    }

    // 홈 화면 등 사이트 설정: 읽기는 누구나, 쓰기는 관리자만
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && isAdminEmail(request.auth.token.email);
    }
  }
}
